[Unit]
Description=AegisShield TC/eBPF DDoS Protection
Documentation=https://github.com/k4ran909/Aegisshield
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStartPre=-/usr/sbin/tc qdisc del dev eth0 clsact
ExecStartPre=-/bin/rm -rf /sys/fs/bpf/aegis
ExecStart=/root/Aegisshield/data-plane/target/release/aegis-loader --interface eth0 --config /root/Aegisshield/configs/aegis.yaml
ExecStopPost=-/usr/sbin/tc qdisc del dev eth0 clsact
ExecStopPost=-/bin/rm -rf /sys/fs/bpf/aegis

# Auto-restart on crash
Restart=always
RestartSec=5

# Environment
Environment=RUST_LOG=info

# CRITICAL: Prevent OOM killer from targeting AegisShield
OOMScoreAdjust=-999

# BPF needs unlimited locked memory
LimitMEMLOCK=infinity
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
